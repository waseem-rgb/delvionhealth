// ─────────────────────────────────────────────
// MULTI-TENANCY CORE
// ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter")
  isActive  Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches        TenantBranch[]
  users           User[]
  patients        Patient[]
  orders          Order[]
  testCatalog     TestCatalog[]
  testPackages    TestPackage[]
  samples         Sample[]
  testResults     TestResult[]
  labReports      LabReport[]
  referenceRanges ReferenceRange[]
  qcRuns          QCRun[]
  instruments     Instrument[]
  appointments    Appointment[]
  doctors         Doctor[]
  leads           Lead[]
  campaigns       Campaign[]
  territories     Territory[]
  invoices        Invoice[]
  payments        Payment[]
  insuranceClaims InsuranceClaim[]
  glAccounts      GLAccount[]
  journalEntries  JournalEntry[]
  employees       Employee[]
  attendances     Attendance[]
  leaves          Leave[]
  shifts          Shift[]
  vendors         Vendor[]
  purchaseOrders  PurchaseOrder[]
  inventoryItems  InventoryItem[]
  stockMovements  StockMovement[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  webhookConfigs          WebhookConfig[]
  notificationPreferences NotificationPreference[]
  apiKeys                 ApiKey[]
  bankAccounts            BankAccount[]
  doctorCommissions       DoctorCommission[]
  revenueTargets          RevenueTarget[]
  standingOrders          StandingOrder[]
  qcEntries               QCEntry[]
  capas                   CAPA[]
  criticalValueAcks       CriticalValueAck[]
  paymentPlans            PatientPaymentPlan[]
  leaveTypes              LeaveType[]
  leaveRequests           LeaveRequest[]
  payrollRuns             PayrollRun[]
  goodsReceivedNotes      GoodsReceivedNote[]
  inventoryLots           InventoryLot[]
  healthProfiles          PatientHealthProfile[]
  familyProfiles          FamilyProfile[]
  instrumentConnections   InstrumentConnection[]
  instrumentMessages      InstrumentMessage[]
  temperatureLoggers      TemperatureLogger[]

  status           TenantStatus      @default(ACTIVE)
  provisionedAt    DateTime?
  suspendedAt      DateTime?
  suspendReason    String?
  onboardingStep   Int               @default(0)
  logoUrl          String?
  primaryColor     String?           @default("#0D7E8A")
  customDomain     String?           @unique
  adminEmail       String?
  maxUsers         Int               @default(10)
  maxBranches      Int               @default(1)
  planId           String?

  subscription     TenantSubscription?
  subscriptionPlan SubscriptionPlan?  @relation(fields: [planId], references: [id])
  platformInvoices PlatformInvoice[]
  usageRecords     UsageRecord[]
  featureFlagOverrides FeatureFlagOverride[]
  tenantAuditLogs  TenantAuditLog[]

  // Phase E-G relations
  maxDiscountPct              Float    @default(100)
  requireDiscountApproval     Boolean  @default(false)
  discountApprovalThreshold   Float    @default(20)
  reportTemplates             ReportTemplate[]
  reportDispatches            ReportDispatch[]
  organizations               Organization[]
  b2bInvoices                 B2BInvoice[]
  b2bPayments                 B2BPayment[]
  referenceLabs               Referencelab[]
  outsourcedSamples           OutsourcedSample[]
  discountApprovals           DiscountApproval[]
  rateLists                   RateList[]
  corporateCamps              CorporateCamp[]
  wellnessDashboards          WellnessDashboard[]
  qualityDocuments            QualityDocument[]
  qualityAuditEntries         QualityAuditEntry[]
  nonConformances             NonConformance[]
  instrumentMaintenanceLogs   InstrumentMaintenanceLog[]
  eqasRounds                  EQASRound[]
  complianceCerts             ComplianceCert[]
  qualityForms                QualityForm[]
  qualityCapas                QualityCapa[]
  reportParameters            ReportParameter[]
  reportSettings              ReportSetting[]

  // Report branding
  reportHeaderHtml     String?   @db.Text
  reportFooterHtml     String?   @db.Text
  reportHeaderImageUrl String?
  reportFooterImageUrl String?
  showHeaderFooter     Boolean   @default(true)

  // Voice Agent
  agentSessions       AgentSession[]
  agentWidgetConfig   AgentWidgetConfig?
  agentAppointments   AgentAppointment[]

  // Revenue CRM
  salesReps           SalesRep[]
  salesVisits         SalesVisit[]
  salesTargets        SalesTarget[]
  b2bAccounts         B2BAccount[]
  corporateContracts  CorporateContract[]
  tpaAccounts         TPAAccount[]
  salesDeals          SalesDeal[]
  healthCamps         HealthCamp[]
  coupons             Coupon[]
  couponUsages        CouponUsage[]
  bankStatementUploads BankStatementUpload[]
  bankStatementLines   BankStatementLine[]
  vendorInvoices       VendorInvoice[]
  patientSegments     PatientSegment[]
  customQuotes        CustomQuote[]
  aiPackageSessions   AIPackageSession[]

  @@map("tenants")
}

model TenantBranch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  city      String?
  state     String?
  country   String   @default("IN")
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patients     Patient[]
  orders       Order[]
  samples      Sample[]
  qcRuns       QCRun[]
  instruments  Instrument[]
  appointments Appointment[]
  employees    Employee[]
  attendances  Attendance[]
  shifts       Shift[]

  @@index([tenantId])
  @@map("tenant_branches")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  role         Role      @default(FRONT_DESK)
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdOrders      Order[]              @relation("OrderCreatedBy")
  verifiedResults    TestResult[]         @relation("ResultVerifiedBy")
  enteredResults     TestResult[]         @relation("ResultEnteredBy")
  validatedResults   TestResult[]         @relation("ResultValidatedBy")
  signedResults      TestResult[]         @relation("ResultSignedBy")
  signedReports      LabReport[]          @relation("ReportSignedBy")
  qcRuns             QCRun[]
  resolvedViolations QCViolation[]
  visitedDoctors     DoctorVisit[]        @relation("VisitedBy")
  assignedLeads      Lead[]               @relation("LeadAssignedTo")
  collectedSamples   Sample[]             @relation("SampleCollectedBy")
  receivedSamples    Sample[]             @relation("SampleReceivedBy")
  accessionedSamples Sample[]             @relation("SampleAccessionedBy")
  movedSamples       SampleMovement[]     @relation("SampleMovedBy")
  rejectedSamples    SpecimenRejection[]  @relation("RejectedBy")
  journalEntries     JournalEntry[]
  approvedLeaves     Leave[]              @relation("LeaveApprovedBy")
  stockMovements     StockMovement[]      @relation("StockMovedBy")
  auditLogs          AuditLog[]
  notifications      Notification[]
  employee           Employee?
  territories        Territory[]
  recordedPayments   Payment[]        @relation("PaymentRecordedBy")
  createdInvoices    Invoice[]        @relation("InvoiceCreatedBy")
  leadNotes              LeadNote[]              @relation("LeadNoteCreatedBy")
  notificationPreference NotificationPreference?
  apiKeys                ApiKey[]               @relation("ApiKeyCreatedBy")
  pushTokens             PushToken[]
  patients               Patient[]

  // Lab pipeline
  accessionedOrders      Order[]              @relation("OrderAccessionedBy")

  // Phase E-G
  signatureUrl           String?
  canApproveReports      Boolean  @default(false)
  approvedReports        LabReport[]  @relation("ReportApprovedBy")
  rejectedReports        LabReport[]  @relation("ReportRejectedBy")

  statementUploads   BankStatementUpload[] @relation("StatementUploadedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// PATIENT & ORDERS (LMIS)
// ─────────────────────────────────────────────

model Patient {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  mrn              String
  firstName        String
  lastName         String
  dob              DateTime
  gender           String
  phone            String
  email            String?
  userId           String?  @unique
  address          String?
  city             String?
  state            String?
  pincode          String?
  designation      String?
  patientType      String?  @default("REGULAR")
  notes            String?
  insuranceId      String?
  referringDoctorId String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch       TenantBranch  @relation(fields: [branchId], references: [id])
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders       Order[]
  appointments Appointment[]
  invoices     Invoice[]
  healthProfile           PatientHealthProfile?
  familyProfilesAsPrimary FamilyProfile[]       @relation("FamilyPrimary")
  familyProfilesAsMember  FamilyProfile[]       @relation("FamilyMember")
  standingOrders          StandingOrder[]
  paymentPlans            PatientPaymentPlan[]

  // Phase G2: Merge patients
  mergedIntoId  String?
  mergedAt      DateTime?

  @@unique([tenantId, mrn])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, lastName, firstName])
  @@map("patients")
}

model Order {
  id             String      @id @default(cuid())
  tenantId       String
  branchId       String
  patientId      String
  orderNumber    String
  status         OrderStatus @default(PENDING)
  priority       String      @default("ROUTINE")
  totalAmount    Decimal     @db.Decimal(12, 2) @default(0)
  discountAmount Decimal     @db.Decimal(12, 2) @default(0)
  netAmount      Decimal     @db.Decimal(12, 2) @default(0)
  paymentStatus  String      @default("UNPAID")
  notes          String?
  // Coupon & source tracking
  couponId       String?
  couponCode     String?
  couponDiscount Decimal?    @db.Decimal(8, 2) @default(0)
  discountType   String?
  campaignId     String?
  sourceChannel  String?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      TenantBranch @relation(fields: [branchId], references: [id])
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Restrict)
  createdBy   User         @relation("OrderCreatedBy", fields: [createdById], references: [id])
  items       OrderItem[]
  samples     Sample[]
  testResults TestResult[]
  labReports  LabReport[]
  invoices    Invoice[]

  // Billing fields
  billedAt        DateTime?
  billingStatus   String?       @default("PENDING")

  // Lab pipeline fields
  collectionType      CollectionType  @default(WALK_IN)
  collectionDateTime  DateTime?
  accessionedAt       DateTime?
  accessionedById     String?
  accessionedBy       User?            @relation("OrderAccessionedBy", fields: [accessionedById], references: [id])
  rejectionReason     SampleRejectionReason?
  rejectionNote       String?
  processingStartedAt DateTime?
  resultSubmittedAt   DateTime?
  approvedAt          DateTime?
  dispatchedAt        DateTime?
  archivedAt          DateTime?
  archiveRack         String?
  archiveShelf        String?
  archiveBox          String?
  archivePosition     String?

  // Organisation / Credit
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  isCreditOrder       Boolean       @default(false)

  // Phase E-G
  b2bLineItems      B2BInvoiceLineItem[]
  outsourcedSamples OutsourcedSample[]
  discountApproval  DiscountApproval?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String
  testCatalogId String
  quantity      Int         @default(1)
  price         Decimal     @db.Decimal(12, 2)
  discount      Decimal     @db.Decimal(5, 2) @default(0)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  testCatalog TestCatalog @relation(fields: [testCatalogId], references: [id])
  testResults TestResult[]

  @@index([orderId])
  @@map("order_items")
}

model TestCatalog {
  id              String   @id @default(cuid())
  tenantId        String
  code            String
  name            String
  category        String
  department      String
  price           Decimal  @db.Decimal(12, 2)
  turnaroundHours Int      @default(24)
  loincCode       String?
  snomedCode      String?
  sampleType      String?
  sampleVolume    String?
  methodology     String?
  type            String?
  schedule        String?
  cptCode         String?  @db.VarChar(20)
  cogs            Decimal? @db.Decimal(10, 2)
  b2bPrice        Decimal? @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Report template fields
  reportTitle          String?
  reportIntro          String?  @db.Text
  reportConclusion     String?  @db.Text
  clinicalSignificance String?  @db.Text
  preparationNote      String?
  collectionNote       String?
  isTemplateComplete   Boolean  @default(false)
  templateLastEditedById String?
  templateLastEditedAt   DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  referenceRanges  ReferenceRange[]
  reflabTests      ReflabTest[]
  outsourcedTests  OutsourcedTest[]
  rateListItems    RateListItem[]
  testPackage      TestPackage?
  reportParameters ReportParameter[]
  reportSettings   ReportSetting[]
  testNotes        TestNote[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, category])
  @@map("test_catalog")
}

model TestPackage {
  id             String   @id @default(cuid())
  tenantId       String
  testCatalogId  String?  @unique
  name           String
  description    String?
  price          Decimal  @db.Decimal(12, 2)
  discountAmount Decimal  @db.Decimal(12, 2) @default(0)
  componentTotal Decimal  @db.Decimal(12, 2) @default(0)
  items          Json     @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  testCatalog TestCatalog? @relation(fields: [testCatalogId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("test_packages")
}

// ─────────────────────────────────────────────
// SAMPLE MANAGEMENT
// ─────────────────────────────────────────────

model Sample {
  id            String       @id @default(cuid())
  tenantId      String
  orderId       String
  barcodeId     String       @unique
  type          String
  collectedAt   DateTime?
  collectedById String?
  receivedAt    DateTime?
  receivedById  String?
  status        SampleStatus @default(PENDING_COLLECTION)
  location      String?
  branchId      String
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Lab pipeline fields
  vacutainerType      String?
  volumeRequired      Float?
  volumeCollected     Float?
  tubeCount           Int?
  isStatSample        Boolean  @default(false)
  specialInstructions String?

  // Accession v2 fields
  tube              String?    // EDTA | SERUM | NASOPHARYNGEAL | URINE | STOOL | CSF | SPUTUM
  accessionedAt     DateTime?
  accessionedById   String?
  testIds           String[]   @default([])

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order               @relation(fields: [orderId], references: [id])
  branch        TenantBranch        @relation(fields: [branchId], references: [id])
  collectedBy   User?               @relation("SampleCollectedBy", fields: [collectedById], references: [id])
  receivedBy    User?               @relation("SampleReceivedBy", fields: [receivedById], references: [id])
  accessionedBy User?               @relation("SampleAccessionedBy", fields: [accessionedById], references: [id])
  movements     SampleMovement[]
  rejections    SpecimenRejection[]
  testResults   TestResult[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([orderId])
  @@map("samples")
}

model SampleMovement {
  id           String   @id @default(cuid())
  sampleId     String
  fromLocation String?
  toLocation   String
  movedById    String
  movedAt      DateTime @default(now())
  notes        String?

  sample  Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  movedBy User   @relation("SampleMovedBy", fields: [movedById], references: [id])

  @@index([sampleId])
  @@map("sample_movements")
}

model SpecimenRejection {
  id           String   @id @default(cuid())
  sampleId     String
  reason       String
  rejectedById String
  rejectedAt   DateTime @default(now())
  notified     Boolean  @default(false)
  notes        String?

  sample     Sample @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  rejectedBy User   @relation("RejectedBy", fields: [rejectedById], references: [id])

  @@index([sampleId])
  @@map("specimen_rejections")
}

// ─────────────────────────────────────────────
// RESULTS & REPORTS
// ─────────────────────────────────────────────

model TestResult {
  id               String               @id @default(cuid())
  tenantId         String
  orderId          String
  orderItemId      String
  sampleId         String
  value            String
  numericValue     Float?
  unit             String?
  referenceRange   String?
  interpretation   ResultInterpretation @default(NORMAL)
  flags            String?
  isDraft          Boolean              @default(true)
  deltaFlagged     Boolean              @default(false)
  deltaPercent     Float?
  previousValue    Float?
  enteredById      String?
  verifiedById     String?
  verifiedAt       DateTime?
  autoVerified     Boolean              @default(false)
  validatedById    String?
  validatedAt      DateTime?
  pathologistNotes String?
  reportedAt       DateTime?
  isAutoPopulated  Boolean              @default(false)
  instrumentId     String?
  signedById       String?
  signedAt         DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       Order      @relation(fields: [orderId], references: [id])
  orderItem   OrderItem  @relation(fields: [orderItemId], references: [id])
  sample      Sample     @relation(fields: [sampleId], references: [id])
  enteredBy         User?              @relation("ResultEnteredBy", fields: [enteredById], references: [id])
  verifiedBy        User?              @relation("ResultVerifiedBy", fields: [verifiedById], references: [id])
  validatedBy       User?              @relation("ResultValidatedBy", fields: [validatedById], references: [id])
  signedBy          User?              @relation("ResultSignedBy", fields: [signedById], references: [id])
  instrument        Instrument?        @relation(fields: [instrumentId], references: [id])
  criticalValueAcks CriticalValueAck[]

  @@index([tenantId])
  @@index([orderId])
  @@index([tenantId, interpretation])
  @@map("test_results")
}

model LabReport {
  id           String       @id @default(cuid())
  tenantId     String
  orderId      String
  reportNumber String
  status       ReportStatus @default(DRAFT)
  pdfUrl       String?
  signedById   String?
  signedAt     DateTime?
  deliveredAt  DateTime?
  reportedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order    Order  @relation(fields: [orderId], references: [id])
  signedBy User?  @relation("ReportSignedBy", fields: [signedById], references: [id])

  // Phase E2: Approval
  approvalStatus  ReportApprovalStatus @default(PENDING)
  approvedById    String?
  approvedBy      User?    @relation("ReportApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?    @relation("ReportRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?
  signatureUrl    String?

  // Phase E1: Template
  templateId      String?
  template        ReportTemplate? @relation(fields: [templateId], references: [id])

  // Phase E3: Dispatch
  dispatchStatus  DispatchStatus  @default(NOT_SENT)
  dispatchedAt    DateTime?
  dispatches      ReportDispatch[]

  @@unique([tenantId, reportNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, approvalStatus])
  @@map("lab_reports")
}

model ReferenceRange {
  id                String   @id @default(cuid())
  tenantId          String
  testCatalogId     String
  reportParameterId String?
  genderFilter      String?
  ageMinYears       Int?
  ageMaxYears       Int?
  lowNormal         Float?
  highNormal        Float?
  lowCritical       Float?
  highCritical      Float?
  unit              String?
  notes             String?
  createdAt         DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  testCatalog     TestCatalog      @relation(fields: [testCatalogId], references: [id], onDelete: Cascade)
  reportParameter ReportParameter? @relation(fields: [reportParameterId], references: [id], onDelete: SetNull)

  @@index([tenantId, testCatalogId])
  @@index([reportParameterId])
  @@map("reference_ranges")
}

// ─────────────────────────────────────────────
// QC MODULE
// ─────────────────────────────────────────────

model QCRun {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String
  instrumentId String
  analyte      String
  level        String
  value        Decimal  @db.Decimal(12, 4)
  mean         Decimal  @db.Decimal(12, 4)
  sd           Decimal  @db.Decimal(12, 4)
  cv           Decimal  @db.Decimal(8, 4)
  westgardFlag String?
  runById      String
  runAt        DateTime @default(now())
  department   String?
  parameter    String?
  lotNo        String?
  expiryDate   DateTime?
  observedValue Decimal? @db.Decimal(10, 4)
  zScore       Decimal? @db.Decimal(6, 3)
  isAccepted   Boolean  @default(true)
  capaId       String?
  updatedAt    DateTime? @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     TenantBranch @relation(fields: [branchId], references: [id])
  instrument Instrument  @relation(fields: [instrumentId], references: [id])
  runBy      User        @relation(fields: [runById], references: [id])
  violations QCViolation[]

  @@index([tenantId])
  @@index([tenantId, instrumentId])
  @@index([tenantId, department, runAt])
  @@index([runAt])
  @@map("qc_runs")
}

model QCViolation {
  id           String    @id @default(cuid())
  qcRunId      String
  rule         String
  action       String?
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  qcRun      QCRun  @relation(fields: [qcRunId], references: [id], onDelete: Cascade)
  resolvedBy User?  @relation(fields: [resolvedById], references: [id])

  @@index([qcRunId])
  @@map("qc_violations")
}

model Instrument {
  id               String           @id @default(cuid())
  tenantId         String
  branchId         String
  name             String
  model            String?
  manufacturer     String?
  brand            String?
  serialNumber     String?
  department       String?
  status           InstrumentStatus @default(ACTIVE)
  lastCalibration  DateTime?
  nextCalibration  DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      TenantBranch          @relation(fields: [branchId], references: [id])
  qcRuns      QCRun[]
  connections     InstrumentConnection[]
  testResults     TestResult[]
  maintenanceLogs InstrumentMaintenanceLog[]
  cptEntries      InstrumentCPT[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("instruments")
}

// ─────────────────────────────────────────────
// CRM & REVENUE
// ─────────────────────────────────────────────

model Doctor {
  id                 String    @id @default(cuid())
  tenantId           String
  name               String
  salutation         String    @default("Dr.")
  firstName          String?
  lastName           String?
  displayName        String?
  specialty          String?
  phone              String?
  alternateEmail     String?
  email              String?
  dob                DateTime?
  clinicName         String?
  address            String?
  clinicAddress      String?
  city               String?
  state              String?
  pincode            String?
  registrationNumber String?

  // Signing configuration
  passkey            String?
  departments        String[]  @default([])
  isDefault          Boolean   @default(false)
  showOnAppointment  Boolean   @default(true)
  showOnlyAssigned   Boolean   @default(false)

  // Communication
  notifySMS          Boolean   @default(false)
  notifyEmail        Boolean   @default(false)

  // Signature
  signatureImageUrl  String?
  signatureHtml      String?   @db.Text

  // Login
  loginUsername       String?
  loginPassword      String?
  loginEnabled       Boolean   @default(false)
  language           String    @default("en")

  // Availability
  availability       Json?

  // CRM fields
  referralCount      Int       @default(0)
  revenueGenerated   Decimal   @db.Decimal(15, 2) @default(0)
  engagementScore    Int       @default(50)
  lastVisitDate      DateTime?

  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  visits      DoctorVisit[]
  commissions DoctorCommission[]

  @@index([tenantId])
  @@index([tenantId, specialty])
  @@index([tenantId, city])
  @@map("doctors")
}

model Lead {
  id               String     @id @default(cuid())
  tenantId         String
  assignedToId     String?
  source           LeadSource
  status           LeadStatus @default(NEW)
  name             String
  phone            String?
  email            String?
  organizationName String?
  city             String?
  notes            String?
  expectedValue    Decimal?   @db.Decimal(15, 2)
  actualValue      Decimal?   @db.Decimal(15, 2)
  lostReason       String?
  wonAt            DateTime?
  lostAt           DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo User?      @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  leadNotes  LeadNote[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@map("leads")
}

model LeadNote {
  id          String   @id @default(cuid())
  leadId      String
  content     String
  type        NoteType @default(NOTE)
  createdById String
  createdAt   DateTime @default(now())

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User @relation("LeadNoteCreatedBy", fields: [createdById], references: [id])

  @@index([leadId])
  @@map("lead_notes")
}

model DoctorVisit {
  id            String   @id @default(cuid())
  tenantId      String
  doctorId      String
  visitedById   String
  visitedAt     DateTime @default(now())
  purpose       String?
  outcome       String?
  notes         String?
  nextVisitDate DateTime?
  gpsLat        Decimal? @db.Decimal(10, 8)
  gpsLng        Decimal? @db.Decimal(11, 8)
  createdAt     DateTime @default(now())

  doctor    Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  visitedBy User   @relation("VisitedBy", fields: [visitedById], references: [id])

  @@index([doctorId])
  @@index([visitedById])
  @@index([tenantId, visitedAt])
  @@map("doctor_visits")
}

model Campaign {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  type            String
  startDate       DateTime?
  endDate         DateTime?
  budget          Decimal?  @db.Decimal(12, 2)
  spent           Decimal   @db.Decimal(12, 2) @default(0)
  status          String    @default("DRAFT")
  targetAudience  Json      @default("{}")
  targetSegment   String?
  sentCount       Int       @default(0)
  openCount       Int       @default(0)
  conversionCount Int       @default(0)
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("campaigns")
}

model Territory {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  zones         Json     @default("[]")
  assignedToId  String?
  revenueTarget Decimal? @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation(fields: [assignedToId], references: [id])

  @@index([tenantId])
  @@map("territories")
}

// ─────────────────────────────────────────────
// BILLING & RCM
// ─────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  orderId       String?
  patientId     String
  invoiceNumber String
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @db.Decimal(12, 2) @default(0)
  tax           Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  paidAt        DateTime?
  cancelledAt   DateTime?
  notes         String?
  createdById   String?
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order           Order?               @relation(fields: [orderId], references: [id])
  patient         Patient              @relation(fields: [patientId], references: [id])
  createdBy       User?                @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  payments        Payment[]
  insuranceClaims InsuranceClaim[]
  commissions     DoctorCommission[]
  paymentPlans    PatientPaymentPlan[]
  items           InvoiceItem[]
  organizationId  String?
  organization    Organization?    @relation(fields: [organizationId], references: [id])
  amountPaid      Decimal              @db.Decimal(12, 2) @default(0)
  balance         Decimal              @db.Decimal(12, 2) @default(0)
  paymentMode     String               @default("CASH")
  billedAt        DateTime?
  paymentRemark        String?
  paymentRefNumber     String?
  paymentScreenshotUrl String?
  paymentScreenshotKey String?
  insuranceTpaName     String?
  insurancePolicyNo    String?
  isCreditOrder        Boolean          @default(false)
  journalEntryId       String?
  invoiceType          String           @default("PATIENT")
  tdsDeducted          Decimal          @db.Decimal(12, 2) @default(0)

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
  @@map("invoices")
}

model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  invoiceId    String
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  reference    String?
  status       PaymentStatus @default(COMPLETED)
  paidAt       DateTime      @default(now())
  recordedById String?
  notes          String?
  bankAccountId  String?
  journalEntryId String?
  createdAt      DateTime      @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice     Invoice      @relation(fields: [invoiceId], references: [id])
  recordedBy  User?        @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([tenantId, paidAt])
  @@map("payments")
}

model InsuranceClaim {
  id              String      @id @default(cuid())
  tenantId        String
  invoiceId       String
  insurerId       String      @default("")
  insurerName     String?
  memberId        String
  claimNumber     String?
  amount          Decimal     @db.Decimal(12, 2)
  approvedAmount  Decimal?    @db.Decimal(12, 2)
  status          ClaimStatus @default(DRAFT)
  submittedAt     DateTime?
  settledAt       DateTime?
  rejectionReason String?
  notes           String?
  denialCode      String?
  denialReason    String?
  appealedAt      DateTime?
  appealNotes     String?
  resubmittedAt   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("insurance_claims")
}

// ─────────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────────

model GLAccount {
  id            String        @id @default(cuid())
  tenantId      String
  code          String
  name          String
  type          GLAccountType
  normalBalance BalanceType   @default(DEBIT)
  balance       Decimal       @db.Decimal(15, 2) @default(0)
  group         String
  subGroup      String?
  isSystem      Boolean       @default(true)
  openingBalance BigInt       @default(0)
  currentBalance BigInt       @default(0)
  parentId      String?
  isActive      Boolean       @default(true)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent       GLAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     GLAccount[]   @relation("AccountHierarchy")
  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("gl_accounts")
}

model JournalEntry {
  id           String   @id @default(cuid())
  tenantId     String
  entryNumber  String
  description  String?
  date         DateTime
  status       String   @default("POSTED")
  reference    String?
  reversedById String?
  reversedAt   DateTime?
  createdById  String
  createdAt    DateTime @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User          @relation(fields: [createdById], references: [id])
  lines     JournalLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId])
  @@index([tenantId, date])
  @@map("journal_entries")
}

model JournalLine {
  id             String  @id @default(cuid())
  journalEntryId String
  glAccountId    String
  debit          Decimal @db.Decimal(15, 2) @default(0)
  credit         Decimal @db.Decimal(15, 2) @default(0)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  glAccount    GLAccount    @relation(fields: [glAccountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_lines")
}

// ─────────────────────────────────────────────
// HR & STAFF
// ─────────────────────────────────────────────

model Employee {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String   @unique
  employeeCode String
  department   String?
  designation  String?
  branchId     String?
  joiningDate  DateTime
  salary       Decimal? @db.Decimal(12, 2)
  bankAccount  Json?    @default("{}")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])
  branch TenantBranch? @relation(fields: [branchId], references: [id])

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

model Attendance {
  id          String           @id @default(cuid())
  tenantId    String
  employeeId  String
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  hoursWorked Decimal?         @db.Decimal(5, 2)
  branchId    String?

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   TenantBranch? @relation(fields: [branchId], references: [id])

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([tenantId, date])
  @@map("attendances")
}

model Leave {
  id           String      @id @default(cuid())
  tenantId     String
  employeeId   String
  type         String
  startDate    DateTime
  endDate      DateTime
  status       LeaveStatus @default(PENDING)
  approvedById String?
  reason       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvedBy User?  @relation("LeaveApprovedBy", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("leaves")
}

model Shift {
  id        String     @id @default(cuid())
  tenantId  String
  branchId  String
  name      String
  startTime String
  endTime   String
  days      Json       @default("[]")
  type      ShiftType  @default(MORNING)
  isActive  Boolean    @default(true)

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      TenantBranch      @relation(fields: [branchId], references: [id])
  assignments ShiftAssignment[]

  @@index([tenantId])
  @@map("shifts")
}

// ─────────────────────────────────────────────
// INVENTORY & PROCUREMENT
// ─────────────────────────────────────────────

model Vendor {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  contactPerson   String?
  email           String?
  phone           String?
  address         String?
  gstNumber       String?
  paymentTerms    Int?
  rating          Float?
  isActive        Boolean  @default(true)
  code            String?
  panNumber       String?
  tdsApplicable   Boolean  @default(false)
  tdsSection      String   @default("NONE")
  ledgerAccountId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders     PurchaseOrder[]
  inventoryItems     InventoryItem[]
  goodsReceivedNotes GoodsReceivedNote[]
  vendorInvoices     VendorInvoice[]

  @@index([tenantId])
  @@map("vendors")
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  tenantId         String
  vendorId         String
  poNumber         String
  status           POStatus  @default(DRAFT)
  totalAmount      Decimal   @db.Decimal(12, 2) @default(0)
  subtotal         Decimal   @db.Decimal(12, 2) @default(0)
  taxAmount        Decimal   @db.Decimal(12, 2) @default(0)
  expectedDelivery DateTime?
  approvedById     String?
  approvedAt       DateTime?
  notes            String?
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor    Vendor              @relation(fields: [vendorId], references: [id])
  items     PurchaseOrderItem[]
  grns      GoodsReceivedNote[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

model InventoryItem {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  category        String
  unit            String
  code            String?
  ledgerAccountId String?
  currentStock Decimal   @db.Decimal(12, 3) @default(0)
  reorderLevel Decimal   @db.Decimal(12, 3) @default(0)
  expiryDate   DateTime?
  batchNumber  String?
  vendorId     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor    Vendor?         @relation(fields: [vendorId], references: [id])
  movements StockMovement[]
  lots      InventoryLot[]
  grnItems  GRNItem[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("inventory_items")
}

model StockMovement {
  id        String   @id @default(cuid())
  tenantId  String
  itemId    String
  type      String
  quantity  Decimal  @db.Decimal(12, 3)
  reference String?
  movedById String
  movedAt   DateTime @default(now())

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item    InventoryItem @relation(fields: [itemId], references: [id])
  movedBy User          @relation("StockMovedBy", fields: [movedById], references: [id])

  @@index([tenantId])
  @@index([itemId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────
// VENDOR INVOICES & PURCHASE ORDER ITEMS
// ─────────────────────────────────────────────

model VendorInvoice {
  id                  String   @id @default(cuid())
  tenantId            String
  vendorId            String
  vendorInvoiceNumber String
  purchaseOrderId     String?
  grnId               String?
  invoiceDate         DateTime
  dueDate             DateTime?
  subtotal            Decimal  @db.Decimal(12, 2) @default(0)
  tdsAmount           Decimal  @db.Decimal(12, 2) @default(0)
  netPayable          Decimal  @db.Decimal(12, 2) @default(0)
  paidAmount          Decimal  @db.Decimal(12, 2) @default(0)
  status              String   @default("PENDING")
  journalEntryId      String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, vendorId])
  @@map("vendor_invoices")
}

