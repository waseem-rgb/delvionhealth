  month           Int
  year            Int
  revenueTarget   Decimal  @db.Decimal(12, 2)
  revenueActual   Decimal  @db.Decimal(12, 2) @default(0)
  visitTarget     Int      @default(0)
  visitActual     Int      @default(0)
  newDoctorTarget Int      @default(0)
  newDoctorActual Int      @default(0)
  dealTarget      Int      @default(0)
  dealActual      Int      @default(0)
  revShareEarned  Decimal  @db.Decimal(10, 2) @default(0)
  revSharePaid    Boolean  @default(false)
  revSharePaidAt  DateTime?
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rep             SalesRep @relation(fields: [repId], references: [id])

  @@unique([tenantId, repId, month, year])
  @@map("sales_targets")
}

// ─────────────────────────────────────────────
// REVENUE CRM — B2B ACCOUNTS
