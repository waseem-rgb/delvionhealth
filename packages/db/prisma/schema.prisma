// ─────────────────────────────────────────────
// PHASE E5: ORGANIZATION & B2B INVOICING
// ─────────────────────────────────────────────

model Organization {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  code               String
  contactPerson      String?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  pincode            String?
  gstNumber          String?
  panNumber          String?

  // Default referring doctor
  defaultReferringDoctorId   String?
  defaultReferringDoctorName String?

  // Payment configuration
  paymentType        String   @default("WALKIN")   // WALKIN | PREPAID | POSTPAID | FLEXIBLE_PREPAID
  creditDays         Int      @default(30)
  creditLimit        Decimal? @db.Decimal(10, 2)
  startingAdvance    Decimal? @db.Decimal(10, 2)
  currentBalance     Decimal  @db.Decimal(10, 2) @default(0)
  discountPct        Float    @default(0)
  currentOutstanding Float    @default(0)
  totalOrders        Int      @default(0)
  totalRevenue       Float    @default(0)

  // Login access
  loginType          String   @default("NO_LOGIN") // NO_LOGIN | VIEW_ONLY | EDIT_ACCESS
  loginEmail         String?  @unique
  loginPassword      String?

  // Report customization
  showHeaderFooter       Boolean @default(false)
  headerImageUrl         String?
  footerImageUrl         String?
  reportHeaderHtml       String? @db.Text
  reportFooterHtml       String? @db.Text

  // Communication settings
  autoReportEmail        Boolean @default(false)
  autoReportWhatsapp     Boolean @default(false)
  patientCommMode        String  @default("REPORTS_ONLY") // REPORTS_AND_BILLS | REPORTS_ONLY | DISABLED

  // Other settings
  alwaysShowMRP          Boolean @default(false)
  showOnlyPaidReports    Boolean @default(true)
  showSecondaryUnits     Boolean @default(false)
  reportAccess           String  @default("SIGNED") // SIGNED | SUBMITTED

  // Rate list assignment
  rateListId         String?

  // Hierarchy
  parentOrgId        String?

  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rateList    RateList?      @relation(fields: [rateListId], references: [id])
  parentOrg   Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  subOrgs     Organization[] @relation("OrgHierarchy")
  b2bInvoices B2BInvoice[]
  orders      Order[]
  invoices    Invoice[]
  ledger      OrgLedger[]
  wellnessDashboards WellnessDashboard[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("organizations")
}

model B2BInvoice {
  id             String          @id @default(cuid())
