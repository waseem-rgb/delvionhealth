// ─────────────────────────────────────────────
// REVENUE CRM — TPA / INSURANCE
// ─────────────────────────────────────────────

model TPAAccount {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  type             String   @default("TPA")
  contactPerson    String?
  phone            String?
  email            String?
  empanelmentDate  DateTime?
  empanelmentNo    String?
  avgPaymentDays   Int?
  totalClaims      Int      @default(0)
  totalClaimValue  Decimal  @db.Decimal(14, 2) @default(0)
  totalPaid        Decimal  @db.Decimal(14, 2) @default(0)
  totalPending     Decimal  @db.Decimal(14, 2) @default(0)
  rejectionRate    Decimal? @db.Decimal(5, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  claims           TPAClaim[]

  @@index([tenantId])
  @@map("tpa_accounts")
}

model TPAClaim {
  id               String   @id @default(cuid())
  tenantId         String
  tpaId            String
  orderId          String?
  patientName      String
  claimNumber      String?
  preAuthCode      String?
  submittedDate    DateTime
  claimAmount      Decimal  @db.Decimal(10, 2)
  approvedAmount   Decimal? @db.Decimal(10, 2)
  paidAmount       Decimal? @db.Decimal(10, 2)
  status           String   @default("SUBMITTED")
  rejectionReason  String?
  paidDate         DateTime?
  agingDays        Int?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tpa              TPAAccount @relation(fields: [tpaId], references: [id])

  @@index([tenantId, tpaId, status])
  @@map("tpa_claims")
}

// ─────────────────────────────────────────────
// REVENUE CRM — SALES PIPELINE DEALS
// ─────────────────────────────────────────────

model SalesDeal {
  id              String    @id @default(cuid())
  tenantId        String
  title           String
  clientType      String
  clientId        String?
  clientName      String
  dealType        String?
  estimatedValue  Decimal   @db.Decimal(12, 2) @default(0)
  probability     Int       @default(50)
  stage           String    @default("PROSPECTING")
  stageUpdatedAt  DateTime  @default(now())
  expectedCloseDate DateTime?
  actualCloseDate DateTime?
  lostReason      String?
  assignedRepId   String?
  notes           String?   @db.Text
  aiWinScore      Int?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activities      DealActivity[]

  @@index([tenantId, stage])
  @@index([tenantId, assignedRepId])
  @@map("sales_deals")
}

model DealActivity {
  id          String   @id @default(cuid())
  tenantId    String
  dealId      String
  type        String
  notes       String?  @db.Text
  outcome     String?
  doneAt      DateTime @default(now())
  doneById    String?

  deal        SalesDeal @relation(fields: [dealId], references: [id])

  @@index([tenantId, dealId])
  @@map("deal_activities")
}

// ─────────────────────────────────────────────
// REVENUE CRM — COUPONS
// ─────────────────────────────────────────────

model Coupon {
  id              String    @id @default(cuid())
  tenantId        String
  code            String
  name            String
  type            String
  discountType    String    @default("PERCENTAGE")
  discountValue   Decimal   @db.Decimal(8, 2)
  minOrderValue   Decimal?  @db.Decimal(8, 2)
  maxDiscountAmt  Decimal?  @db.Decimal(8, 2)
  applicableTestIds String? @db.Text
  applicablePackageIds String? @db.Text
  targetGender    String?
  targetAgeMin    Int?
  targetAgeMax    Int?
  isFirstVisitOnly Boolean  @default(false)
  maxUsageTotal   Int?
  maxUsagePerPhone Int?     @default(1)
  usageCount      Int       @default(0)
  totalDiscountGiven Decimal @db.Decimal(12, 2) @default(0)
  totalRevenueGenerated Decimal @db.Decimal(14, 2) @default(0)
  validFrom       DateTime
  validTo         DateTime
  isActive        Boolean   @default(true)
  campaignId      String?
  organisationId  String?
  doctorId        String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usages          CouponUsage[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, type])
  @@map("coupons")
}

model CouponUsage {
  id          String   @id @default(cuid())
  tenantId    String
  couponId    String
  orderId     String
  patientId   String?
  patientPhone String?
  discountAmt Decimal  @db.Decimal(8, 2)
  orderTotal  Decimal  @db.Decimal(10, 2)
  usedAt      DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon      Coupon   @relation(fields: [couponId], references: [id])

  @@index([tenantId, couponId])
  @@index([tenantId, orderId])
  @@map("coupon_usages")
}

// ─────────────────────────────────────────────
// REVENUE CRM — REV SHARE LEDGER
// ─────────────────────────────────────────────

model RevShareLedger {
  id               String   @id @default(cuid())
  tenantId         String
  entityType       String
  entityId         String
  entityName       String
  orderId          String
  orderAmount      Decimal  @db.Decimal(12, 2)
  revSharePct      Decimal  @db.Decimal(5, 2)
  revShareAmount   Decimal  @db.Decimal(10, 2)
  month            Int
  year             Int
  status           String   @default("PENDING")
  paidAt           DateTime?
  paidById         String?
  remarks          String?
  createdAt        DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, month, year])
  @@index([tenantId, status])
  @@map("rev_share_ledger")
}

// ─────────────────────────────────────────────
// REVENUE CRM — PATIENT SEGMENT
