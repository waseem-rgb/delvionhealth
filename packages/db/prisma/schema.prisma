// ─────────────────────────────────────────────
// CPT & PACKAGE BUILDER
// ─────────────────────────────────────────────

model InstrumentCPT {
  id               String    @id @default(cuid())
  tenantId         String
  instrumentId     String
  testCatalogId    String
  reagentCost      Decimal   @db.Decimal(10, 2) @default(0)
  controlCost      Decimal   @db.Decimal(10, 2) @default(0)
  consumableCost   Decimal   @db.Decimal(10, 2) @default(0)
  calibrationCost  Decimal   @db.Decimal(10, 2) @default(0)
  overheadCost     Decimal   @db.Decimal(10, 2) @default(0)
  totalCPT         Decimal   @db.Decimal(10, 2) @default(0)
  mrpAtTime        Decimal?  @db.Decimal(10, 2)
  grossMarginAmt   Decimal?  @db.Decimal(10, 2)
  grossMarginPct   Decimal?  @db.Decimal(6, 2)
  notes            String?
  lastEditedById   String?
  lastEditedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  instrument       Instrument @relation(fields: [instrumentId], references: [id])

  @@unique([tenantId, instrumentId, testCatalogId])
  @@index([tenantId, testCatalogId])
  @@map("instrument_cpt")
}

model CustomQuote {
  id               String    @id @default(cuid())
  tenantId         String
  quoteNumber      String
  patientName      String?
  patientPhone     String?
  patientAge       Int?
  patientGender    String?
  symptoms         String?   @db.Text
  aiPromptUsed     String?   @db.Text
  testIds          String?   @db.Text
  testNames        String?   @db.Text
  subtotal         Decimal   @db.Decimal(10, 2) @default(0)
  discountAmt      Decimal   @db.Decimal(10, 2) @default(0)
  discountPct      Decimal?  @db.Decimal(6, 2)
  finalPrice       Decimal   @db.Decimal(10, 2) @default(0)
  status           String    @default("DRAFT")
  convertedOrderId String?
  sentAt           DateTime?
  expiresAt        DateTime?
  savedAsPackageId String?
  createdById      String?
  createdAt        DateTime  @default(now())

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, patientPhone])
  @@map("custom_quotes")
}

model AIPackageSession {
  id            String    @id @default(cuid())
  tenantId      String
  sessionType   String    @default("PACKAGE_BUILDER")
  messages      String    @db.Text
  resultTestIds String?   @db.Text
  savedAs       String?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("ai_package_sessions")
}
