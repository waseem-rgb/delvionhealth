model B2BAccount {
  id               String    @id @default(cuid())
  tenantId         String
  type             String
  name             String
  contactPerson    String?
  phone            String?
  email            String?
  address          String?
  city             String?
  pincode          String?
  website          String?
  rateListId       String?
  creditDays       Int?      @default(30)
  creditLimit      Decimal?  @db.Decimal(12, 2)
  paymentTerms     String?
  pickupSchedule   String?
  tatSlaHours      Int?
  platformName     String?
  platformCommissionPct Decimal? @db.Decimal(5, 2)
  totalRevenue     Decimal   @db.Decimal(14, 2) @default(0)
  revenueMTD       Decimal   @db.Decimal(12, 2) @default(0)
  outstandingAmt   Decimal   @db.Decimal(12, 2) @default(0)
  status           String    @default("ACTIVE")
  assignedRepId    String?
  addedById        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, status])
  @@map("b2b_accounts")
}

// ─────────────────────────────────────────────
// REVENUE CRM — CORPORATE CONTRACT
